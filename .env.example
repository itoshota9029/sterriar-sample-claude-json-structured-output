# Copy to .env and fill in your values.
# Required for running `examples/` scripts live against Claude API.
# Not required for `pytest` (tests use mocked responses).

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the model used in examples.
# Default is "claude-sonnet-4-5" (Claude 4.5 Sonnet).
# CLAUDE_MODEL=claude-sonnet-4-5
